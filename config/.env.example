# Copy to config/.env and fill in, OR use the in-app "System Config" page (keys stay in session unless you save to .env).
# config/.env is gitignored — never commit real keys.

# CLI / scripts (e.g. scripts/run_qc_field_trial.py --live): which vendor to use outside Streamlit
# RAGD_PRIMARY_PROVIDER=google
# RAGD_PRIMARY_PROVIDER=openai
# RAGD_PRIMARY_PROVIDER=anthropic

# --- Pick one provider (match selection in the app) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# Optional
LINE_NOTIFY_TOKEN=

# Optional path overrides (defaults: ./raw_data and ./knowledge)
# RAW_DATA_PATH=
# CLEANED_DATA_PATH=
