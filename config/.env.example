# Copy to config/.env and fill in (never commit config/.env).
#   cp config/.env.example config/.env
# Or use the in-app "System Config" page (keys stay in session until you save to .env).

# CLI / scripts without Streamlit (e.g. scripts/run_qc_field_trial.py --live)
# RAGD_PRIMARY_PROVIDER=google
# RAGD_PRIMARY_PROVIDER=openai
# RAGD_PRIMARY_PROVIDER=anthropic

# --- LLM (match the provider you select in the UI) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# Optional: GitHub API for future tooling
GITHUB_TOKEN=

# Optional path overrides (defaults: ./raw_data and ./knowledge; Docker Compose sets /app/... in the container)
# RAW_DATA_PATH=
# CLEANED_DATA_PATH=

# --- Notifications (optional) ---
LINE_NOTIFY_TOKEN=
DISCORD_WEBHOOK_URL=
