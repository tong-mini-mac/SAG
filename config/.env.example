# Copy to config/.env and fill in (never commit config/.env)
#   cp config/.env.example config/.env

# --- LLM (at least one provider used by the UI) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: GitHub API for future tooling
GITHUB_TOKEN=

# --- Paths (defaults match docker-compose volume mounts) ---
# RAW_DATA_PATH=/app/raw_data
# CLEANED_DATA_PATH=/app/knowledge

# --- Notifications (optional) ---
LINE_NOTIFY_TOKEN=
